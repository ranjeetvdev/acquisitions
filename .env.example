# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=

# Authentication
JWT_SECRET=your-secret-key
JWT_REFRESH_SECRET=refreshsecretkey

ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Cookie
COOKIE_MAX_AGE=15 * 60 * 1000 # minute * second * millisecond (15 minutes in milliseconds) Should be same as ACCESS_TOKEN_EXPIRES value

# Arcjet
ARCJET_KEY=
